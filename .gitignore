# .gitignore para Darom SA - Versión 2026
# Ver https://help.github.com/articles/ignoring-files/ para más detalles.

# Directorios de dependencias obligatorios
/node_modules/
/.pnp
.pnp.js

# Reportes de cobertura de testing
/coverage/

# Carpetas de compilación para producción (Soporta CRA y Vite)
/build/
/dist/
/out/

# Caché de linters y formateadores
.eslintcache
*.cache

# Archivos basura del Sistema Operativo
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# Variables de entorno secretas (¡CRÍTICO no subirlas nunca!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env/*.local

# Archivos de logs de NPM / Yarn / PNPM
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Carpetas de configuración de Editores e IDEs
/.idea/
/.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Archivos y carpetas temporales
/tmp/
*.tmp
*.temp